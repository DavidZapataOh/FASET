-- | Tests for the atomic settlement choice `Settle` (CONTEXT.md ADR-06/07, §6).
--   This task (sprint-03/02) locks in the DELEGATION contract: `Settle` lives on the
--   supplier-signed `InvoiceSettlementAuthorization`, and ONLY the operator (the
--   delegated controller) can submit it — encoding the hard rule "solo el operator
--   somete Settle" (CLAUDE.md) and the {supplier, operator} authority of ADR-06/07.
--   The real two-branch effects (cash leg, invoice cession, Registration, registry
--   compare-and-set) are driven by tasks 03 (success), 04 (atomicity), 05 (reject).
module Faset.Scripts.TestSettle where

import Daml.Script
import DA.Assert ((===))
import DA.Optional (isNone)
import qualified DA.Set as Set

import Faset.Registry (RegistryState(..))
import Faset.Registration (Registration(..), RegistrationRejected(..))
import Faset.Cash (CashHolding(..), CashLock(..))
import Faset.Types (RejectReason(..))
import Faset.Settlement (InvoiceSettlementAuthorization(..), Settle(..))
import Faset.Scripts.TestSettleSetup (setupDeal)

-- | Delegation invariant: the operator — and only the operator — can submit
--   `Settle` on the supplier-signed authorization, and Settle consumes it.
--   A non-controller (the supplier, even as the signatory) must be rejected.
test_onlyOperatorSettlesAndConsumesAuth : Script ()
test_onlyOperatorSettlesAndConsumesAuth = script do
  (operator, supplier, financierA, _, invCid, lockCid, ih) <- setupDeal 1000.0 900.0
  rsCid <- submit operator $ createCmd RegistryState with
    operator = operator
    financed = Set.empty
  authCid <- submit supplier $ createCmd InvoiceSettlementAuthorization with
    supplier = supplier
    operator = operator
    winningFinancier = financierA
    invoiceHash = ih
    expectedAdvance = 900.0
  -- The supplier signed the authorization but is NOT the controller of Settle →
  -- it must not be able to submit it (only the operator may — ADR-07).
  submitMustFail supplier $ exerciseCmd authCid Settle with
    registryStateCid = rsCid
    cashLockCid = lockCid
    invoiceCid = invCid
  -- The operator (delegated controller) settles. Explicit disclosure: the supplier
  -- discloses the Invoice and the financier the CashHolding to the operator's
  -- submission (actAs stays [operator] → only the operator submits; ADR-07/§0).
  Some invDisc <- queryDisclosure supplier invCid
  [(holdingCid, _)] <- query @CashHolding financierA
  Some holdingDisc <- queryDisclosure financierA holdingCid
  submit (actAs operator <> discloseMany [invDisc, holdingDisc]) $ exerciseCmd authCid Settle with
    registryStateCid = rsCid
    cashLockCid = lockCid
    invoiceCid = invCid
  mAuth <- queryContractId supplier authCid
  assertMsg "Settle must consume the InvoiceSettlementAuthorization" (isNone mAuth)

-- | Happy path (atomic DvP, ADR-06 success branch / ADR-07 economics): a clean
--   Settle registers the hash, moves the advance to the supplier as cash, cedes
--   the invoice (archive), and records the winner's economics in a Registration.
--   All in one transaction — the cash create (supplier authority) and the source
--   archive (financier authority, inside CashLock_Execute) commit atomically.
test_settleHappyPath : Script ()
test_settleHappyPath = script do
  (operator, supplier, financierA, _, invCid, lockCid, ih) <- setupDeal 1000.0 900.0
  rsCid <- submit operator $ createCmd RegistryState with
    operator = operator
    financed = Set.empty
  authCid <- submit supplier $ createCmd InvoiceSettlementAuthorization with
    supplier = supplier
    operator = operator
    winningFinancier = financierA
    invoiceHash = ih
    expectedAdvance = 900.0
  -- Explicit disclosure: supplier discloses the Invoice, financier the CashHolding,
  -- to the operator's submission. Submission MECHANISM only — actAs stays [operator]
  -- ("solo el operator somete"); the assertions below are unchanged.
  Some invDisc <- queryDisclosure supplier invCid
  [(holdingCid, _)] <- query @CashHolding financierA
  Some holdingDisc <- queryDisclosure financierA holdingCid
  submit (actAs operator <> discloseMany [invDisc, holdingDisc]) $ exerciseCmd authCid Settle with
    registryStateCid = rsCid
    cashLockCid = lockCid
    invoiceCid = invCid
  -- (vi) Registration records the winner's economics (advance / winner / derived rate).
  [(_, reg)] <- query @Registration operator
  reg.advance === 900.0
  reg.winningFinancier === financierA
  reg.rate === 0.1   -- (faceValue - advance)/faceValue = (1000 - 900)/1000
  -- cash leg: the supplier now holds the 900 advance.
  supHoldings <- query @CashHolding supplier
  assertMsg "supplier must hold the 900 advance as cash"
    (any (\(_, h) -> h.amount == 900.0) supHoldings)
  -- (v) registral cession: the invoice is archived (ceded away from the supplier).
  mInv <- queryContractId supplier invCid
  assertMsg "invoice must be archived (registral cession)" (isNone mInv)
  -- (iii) the hash is now in the Single-Pledge index.
  [(_, rs)] <- query @RegistryState operator
  assertMsg "invoiceHash must be registered in RegistryState.financed"
    (Set.member ih rs.financed)

-- | Test 5 (atomicity, ADR-06 / §6): a Settle whose cash leg fails on insufficient
--   funds reverts the WHOLE transaction — including the registry hash inserted in
--   step (iii) BEFORE the cash execute (iv). This proves insert-then-revert
--   atomicity (never a "burnt hash"), not mere pre-check ordering: funded 500 <
--   advance 900, but fairness (900 >= expectedAdvance 900) passes, so the hash IS
--   inserted, then CashLock_Execute throws (holding 500 < 900) → full rollback.
--   Real sufficiency is checked ONLY inside CashLock_Execute (vs holding.amount),
--   never in the Settle body — otherwise this test would pass trivially.
test_settleInsufficientFundsRevertsHash : Script ()
test_settleInsufficientFundsRevertsHash = script do
  (operator, supplier, financierA, _, invCid, lockCid, ih) <- setupDeal 500.0 900.0
  rsCid <- submit operator $ createCmd RegistryState with
    operator = operator
    financed = Set.empty
  authCid <- submit supplier $ createCmd InvoiceSettlementAuthorization with
    supplier = supplier
    operator = operator
    winningFinancier = financierA
    invoiceHash = ih
    expectedAdvance = 900.0
  Some invDisc <- queryDisclosure supplier invCid
  [(holdingCid, _)] <- query @CashHolding financierA
  Some holdingDisc <- queryDisclosure financierA holdingCid
  -- The settle MUST fail: the cash execute throws on insufficient funds (iv).
  submitMustFail (actAs operator <> discloseMany [invDisc, holdingDisc]) $
    exerciseCmd authCid Settle with
      registryStateCid = rsCid
      cashLockCid = lockCid
      invoiceCid = invCid
  -- Full rollback — nothing persisted:
  [(_, rs)] <- query @RegistryState operator
  Set.member ih rs.financed === False                                -- hash NOT burnt
  regs <- query @Registration operator
  length regs === 0                                                  -- no Registration
  Some _ <- queryContractId supplier invCid                          -- invoice still active
  supHoldings <- query @CashHolding supplier
  length (filter (\(_, h) -> h.amount == 900.0) supHoldings) === 0   -- cash not moved

-- | Test 6 (double-Settle, §6 / ADR-06 / ADR-10): a fraudulent supplier closes with
--   A (settles) then B for the SAME invoiceHash. B's Settle hits the membership gate
--   (hash already financed) → RegistrationRejected, blind ("AlreadyFinanced" only).
--   Exactly ONE Registration (A's), and the cash moved exactly ONCE.
test_doubleSettleRejectsSecond : Script ()
test_doubleSettleRejectsSecond = script do
  (operator, supplier, financierA, financierB, invCid, lockACid, ih) <- setupDeal 1000.0 900.0
  rs0 <- submit operator $ createCmd RegistryState with
    operator = operator
    financed = Set.empty
  authA <- submit supplier $ createCmd InvoiceSettlementAuthorization with
    supplier = supplier
    operator = operator
    winningFinancier = financierA
    invoiceHash = ih
    expectedAdvance = 900.0
  -- A settles (success path → needs Invoice + CashHolding disclosed to the operator).
  Some invDisc <- queryDisclosure supplier invCid
  [(hAcid, _)] <- query @CashHolding financierA
  Some hADisc <- queryDisclosure financierA hAcid
  submit (actAs operator <> discloseMany [invDisc, hADisc]) $ exerciseCmd authA Settle with
    registryStateCid = rs0
    cashLockCid = lockACid
    invoiceCid = invCid
  -- B: own holding + lock, and a fraudulent authorization for the SAME invoiceHash.
  hB <- submit financierB $ createCmd CashHolding with owner = financierB, amount = 1000.0
  lockB <- submit financierB $ createCmd CashLock with
    financier = financierB
    operator = operator
    supplier = supplier
    amount = 900.0
    holdingCid = hB
  authB <- submit supplier $ createCmd InvoiceSettlementAuthorization with
    supplier = supplier
    operator = operator
    winningFinancier = financierB
    invoiceHash = ih
    expectedAdvance = 900.0
  -- Fresh RegistryState cid (A recreated it). B's Settle is rejected at the gate; the
  -- reject branch fetches ONLY RegistryState → no disclosures, invCid never fetched.
  [(rsNowCid, _)] <- query @RegistryState operator
  submit operator $ exerciseCmd authB Settle with
    registryStateCid = rsNowCid
    cashLockCid = lockB
    invoiceCid = invCid
  -- B is blindly rejected; A alone won; cash moved once.
  [(_, rej)] <- query @RegistrationRejected operator
  rej.financier === financierB
  rej.reason === AlreadyFinanced
  regs <- query @Registration operator
  length regs === 1
  supHoldings <- query @CashHolding supplier
  length (filter (\(_, h) -> h.amount == 900.0) supHoldings) === 1

-- | Test 12 (double-Settle with the Invoice ALREADY archived, §6 / ADR-06): after A
--   cedes (archives) the invoice, B's Settle for the same hash must fall into
--   RegistrationRejected CLEANLY — the `submit` SUCCEEDS, it does NOT throw a
--   contract-not-found. This holds only because membership gates BEFORE any Invoice
--   fetch (the reject branch never touches the archived invoice). This is the
--   demo-breaker if it regresses to a contract error instead of "AlreadyFinanced".
test_settleWithArchivedInvoiceRejectsCleanly : Script ()
test_settleWithArchivedInvoiceRejectsCleanly = script do
  (operator, supplier, financierA, financierB, invCid, lockACid, ih) <- setupDeal 1000.0 900.0
  rs0 <- submit operator $ createCmd RegistryState with
    operator = operator
    financed = Set.empty
  authA <- submit supplier $ createCmd InvoiceSettlementAuthorization with
    supplier = supplier
    operator = operator
    winningFinancier = financierA
    invoiceHash = ih
    expectedAdvance = 900.0
  Some invDisc <- queryDisclosure supplier invCid
  [(hAcid, _)] <- query @CashHolding financierA
  Some hADisc <- queryDisclosure financierA hAcid
  submit (actAs operator <> discloseMany [invDisc, hADisc]) $ exerciseCmd authA Settle with
    registryStateCid = rs0
    cashLockCid = lockACid
    invoiceCid = invCid
  -- Precondition: A's invoice is now archived (ceded).
  mInv <- queryContractId supplier invCid
  assertMsg "precondition: A's invoice must be archived" (isNone mInv)
  -- B attempts with the SAME (now archived) invoiceCid.
  hB <- submit financierB $ createCmd CashHolding with owner = financierB, amount = 1000.0
  lockB <- submit financierB $ createCmd CashLock with
    financier = financierB
    operator = operator
    supplier = supplier
    amount = 900.0
    holdingCid = hB
  authB <- submit supplier $ createCmd InvoiceSettlementAuthorization with
    supplier = supplier
    operator = operator
    winningFinancier = financierB
    invoiceHash = ih
    expectedAdvance = 900.0
  [(rsNowCid, _)] <- query @RegistryState operator
  -- KEY: this SUCCEEDS (no contract-not-found) — the reject branch gates on the hash
  -- BEFORE any Invoice fetch, so the archived invoiceCid is never dereferenced.
  submit operator $ exerciseCmd authB Settle with
    registryStateCid = rsNowCid
    cashLockCid = lockB
    invoiceCid = invCid
  rejs <- query @RegistrationRejected operator
  length (filter (\(_, r) -> r.financier == financierB) rejs) === 1
