-- | No-leak invariant tests: a rival financier can never read another party's
--   registry/registration state — the FASET moat (CONTEXT.md §6, tests 1 & 2).
--   These use per-party `queryContractId`, which respects ledger visibility, so
--   they are a REAL partition test, not a mock.
module Faset.Scripts.TestNoLeak where

import Daml.Script
import DA.Optional (isNone)
import qualified DA.Set as Set

import Faset.Registry (RegistryState(..))
import Faset.Registration (Registration(..))
import Faset.Scripts.Setup (allocFasetParties)

-- | Test 1 — the operator-owned Single-Pledge index (`RegistryState`) is
--   invisible to a rival financier: querying it AS FinancierB returns None.
test_registryStateNotVisibleToRival : Script ()
test_registryStateNotVisibleToRival = script do
  (operator, _, _, financierB, _) <- allocFasetParties
  rsCid <- submit operator $ createCmd RegistryState with
    operator = operator
    financed = Set.empty
  mRs <- queryContractId financierB rsCid
  assertMsg "FinancierB (rival) must NOT see RegistryState" (isNone mRs)

-- | Test 2 — the winner's Registration (its economics: faceValue/advance/rate)
--   is invisible to a rival financier: querying it AS FinancierB returns None.
--   Registration observers are {winningFinancier, supplier} only — never a rival.
test_winnerRegistrationNotVisibleToRival : Script ()
test_winnerRegistrationNotVisibleToRival = script do
  (operator, supplier, financierA, financierB, _) <- allocFasetParties
  now <- getTime
  regCid <- submit operator $ createCmd Registration with
    operator = operator
    winningFinancier = financierA
    supplier = supplier
    invoiceHash = "hash-A"
    faceValue = 1000.0
    advance = 900.0
    rate = 0.10
    settledAt = now
  mReg <- queryContractId financierB regCid
  assertMsg "FinancierB (rival) must NOT see the winner's Registration" (isNone mReg)
